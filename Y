        Borda.Color = Color3.fromRGB(80,255,120)
        InfoStatus.Text = "🔍 Escutando aparecimento..."
        LoopAutoColetar()
    else
        ToggleAuto.Text = "🔘  DESATIVADO"
        ToggleAuto.BackgroundColor3 = Color3.fromRGB(45,42,30)
        Borda.Color = Color3.fromRGB(255,200,0)
        InfoStatus.Text = "⏳ Aguardando ativação..."
        if ConexaoPrincipal then ConexaoPrincipal:Disconnect() ConexaoPrincipal = nil end
    end
end)

