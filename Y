-- 🖱️ Arrastar botão
local Arrastando = false
local DifArrasto = Vector2.zero
BotaoAbrir.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        Arrastando = true
        DifArrasto = Vector2.new(i.Position.X,i.Position.Y) - BotaoAbrir.AbsolutePosition
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if Arrastando and i.UserInputType == Enum.UserInputType.MouseMovement then
        local p = Vector2.new(i.Position.X,i.Position.Y) - DifArrasto
        BotaoAbrir.Position = UDim2.new(0,p.X,0,p.Y)
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then Arrastando = false end
end)

-- Abrir/Fechar menu
local MenuAberto = false
local function AlternarMenu()
    if Arrastando then return end
    MenuAberto = not MenuAberto
    if MenuAberto then
        Menu.Visible = true
        Menu.Size = UDim2.new(0,200,0,90)
        Menu.BackgroundTransparency = 1
        TweenService:Create(Menu,TweenInfo.new(.22),{Size=UDim2.new(0,270,0,130),BackgroundTransparency=0}):Play()
    else
        TweenService:Create(Menu,TweenInfo.new(.18),{Size=UDim2.new(0,200,0,90),BackgroundTransparency=1}):Play()
        task.delay(.18,function() Menu.Visible = false end)
    end
end
BotaoAbrir.MouseButton1Click:Connect(AlternarMenu)
FecharBtn.MouseButton1Click:Connect(AlternarMenu)

-- ✨ EFEITOS ORIGINAIS (copiados exatamente dos seus scripts)
local function EfeitoColeta(posicao)
    local PartEfeito = Instance.new("Part")
    PartEfeito.Size = Vector3.new(1,1,1)
    PartEfeito.Position = posicao
    PartEfeito.Anchored = true
    PartEfeito.CanCollide = false
    PartEfeito.Transparency = 1
    PartEfeito.Parent = workspace.Terrain

    local Particula = Instance.new("ParticleEmitter")
    Particula.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,50)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255,200,0)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255,150,0))
    })
    Particula.Size = NumberSequence.new({NumberSequenceKeypoint.new(0,1.5), NumberSequenceKeypoint.new(1,0)})
    Particula.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(0.8,0.3), NumberSequenceKeypoint.new(1,1)})
    Particula.Lifetime = NumberRange.new(0.8,1.5)
    Particula.Speed = NumberRange.new(10,25)
    Particula.SpreadAngle = Vector2.new(360,360)
    Particula.Rate = 0
    Particula.LightEmission = 1
    Particula.Parent = PartEfeito
    Particula:Emit(30)

    local Luz = Instance.new("PointLight")
    Luz.Color = Color3.fromRGB(255,255,100)
    Luz.Brightness = 6
    Luz.Range = 30
    Luz.Parent = PartEfeito

    task.delay(0.2, function()
        TweenService:Create(Luz, TweenInfo.new(0.5), {Brightness=0, Range=0}):Play()
    end)

    Debris:AddItem(PartEfeito, 2)
end

-- 📡 ESCUTA QUANDO CHAVE APARECE — IGUAL O CLIENTE ORIGINAL
SpecialKeyEvent.OnClientEvent:Connect(function(Dados)
    if type(Dados) ~= "table" then return end
    local Acao = Dados.action
    local Posicao = Dados.position

    if Acao == "spawn" and typeof(Posicao) == "Vector3" then
        UltimaPosicaoChave = Posicao
        InfoStatus.Text = "🟡 CHAVE DOURADA DETECTADA!"
        -- Reproduz aviso igual jogo
        NotificationSystem:ShowGeneralNotification("Chave Dourada Encontrada!", Color3.fromRGB(255,200,0), 2)
        SoundManager:Play("SPECIAL_KEY_NOTIF")
    end
end)

-- 🚀 LÓGICA PRINCIPAL: TELETRANSPORTE + COLETA
local function LoopAutoColetar()
    ConexaoPrincipal = RunService.Heartbeat:Connect(function()
        if not AutoGoldenAtivo then return end
        if not UltimaPosicaoChave then return end

        local Personagem = LocalPlayer.Character
        if not Personagem then return end
        local HRP = Personagem:FindFirstChild("HumanoidRootPart")
        if not HRP then return end

        local Agora = tick()
        -- Respeita o tempo mínimo do jogo
        if Agora - CooldownColeta < 0.3 then return end

        -- ✅ TELETRANSPORTE PARA CIMA DA CHAVE
        HRP.CFrame = CFrame.new(UltimaPosicaoChave + Vector3.new(0, 2, 0)) * HRP.CFrame.Rotation

        -- ✅ Efeito visual EXATO do jogo
        EfeitoColeta(UltimaPosicaoChave)

        -- ✅ Notificação de sucesso
        NotificationSystem:ShowGeneralNotification("✅ CHAVE DOURADA COLETADA!", Color3.fromRGB(80,200,50), 2.5)
        InfoStatus.Text = "✅ Coletada — aguardando próxima..."

        -- Limpa para buscar nova
        UltimaPosicaoChave = nil
        CooldownColeta = Agora
    end)
end

-- 🔘 LIGA / DESLIGA
ToggleAuto.MouseButton1Click:Connect(function()
